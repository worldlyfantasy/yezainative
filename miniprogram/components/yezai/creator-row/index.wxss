.creator-row {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.creator-row__main {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.creator-row__avatar {
  width: 132rpx;
  height: 132rpx;
  flex-shrink: 0;
  border-radius: 50%;
  border: 1rpx solid rgba(189, 154, 95, 0.28);
}

.creator-row__body {
  flex: 1;
}

.creator-row__name {
  display: block;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 38rpx;
  line-height: 1.5;
  font-weight: 500;
  color: #2b241d;
}

.creator-row__description {
  display: block;
  margin-top: 10rpx;
  font-size: 27rpx;
  line-height: 1.95;
  color: #6a5a4b;
}

.creator-row__descriptors {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 18rpx;
  margin-top: 14rpx;
}

.creator-row__descriptor,
.creator-row__meta {
  font-size: 22rpx;
  line-height: 1.8;
  color: #993921;
}

.creator-row__meta {
  display: block;
  margin-top: 14rpx;
}
