.section-tabs {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: rgba(248, 240, 222, 0.96);
}

.section-tabs__item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 22rpx 8rpx 18rpx;
}

.section-tabs__label {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 500;
  color: #6a5a4b;
}

.section-tabs__indicator {
  width: 48rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: transparent;
  transition: background 0.2s ease;
}

.section-tabs__item--active .section-tabs__label {
  color: #2b241d;
  font-weight: 600;
}

.section-tabs__item--active .section-tabs__indicator {
  background: #d15e14;
}
