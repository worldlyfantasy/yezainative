.creator-card {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.12);
}

.creator-card__head {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.creator-card__avatar {
  width: 144rpx;
  height: 144rpx;
  flex-shrink: 0;
  border-radius: 50%;
  border: 1rpx solid rgba(189, 154, 95, 0.34);
}

.creator-card__meta {
  flex: 1;
}

.creator-card__title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.creator-card__name {
  display: block;
  flex: 0 0 auto;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 40rpx;
  line-height: 1.45;
  font-weight: 500;
  color: #2b241d;
}

.creator-card__stance {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.9;
  color: #6a5a4b;
}

.creator-card__tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx 12rpx;
  flex: 1;
  padding-top: 6rpx;
}

.creator-card__tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(153, 57, 33, 0.2);
  background: rgba(189, 154, 95, 0.1);
  font-size: 20rpx;
  line-height: 1.2;
  letter-spacing: 1rpx;
  color: #8a5a38;
}
