.bottom-action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(108rpx + env(safe-area-inset-bottom));
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0 0;
  border-top: 1rpx solid rgba(153, 57, 33, 0.14);
  border-radius: 0;
  background: rgba(242, 230, 201, 0.96);
  box-shadow: none;
}

.bottom-action-bar__label {
  display: block;
  font-size: 22rpx;
  color: #6a5a4b;
}

.bottom-action-bar__price {
  display: block;
  margin-top: 4rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #2b241d;
}

.bottom-action-bar__button {
  min-width: 260rpx;
}
