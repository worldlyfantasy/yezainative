.hero-image {
  position: relative;
  width: 100%;
  height: 0;
  padding-top: 56.25%;
  overflow: hidden;
}

.hero-image__media,
.hero-image__overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-image__overlay {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 36rpx 40rpx;
  background: linear-gradient(180deg, rgba(21, 15, 11, 0.04), rgba(21, 15, 11, 0.44) 86%);
}
