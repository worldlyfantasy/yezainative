.destination-card {
  overflow: hidden;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.12);
}

.destination-card__cover {
  display: block;
  width: 100%;
  height: 420rpx;
}

.destination-card__body {
  padding-top: 24rpx;
}

.destination-card__head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.destination-card__name {
  font-family: "STSong", "Songti SC", "Noto Serif CJK SC", serif;
  font-size: 42rpx;
  line-height: 1.45;
  font-weight: 500;
  color: #2b241d;
}

.destination-card__stats {
  font-size: 22rpx;
  color: #6a5a4b;
}

.destination-card__desc {
  display: block;
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.95;
  color: #6a5a4b;
}
