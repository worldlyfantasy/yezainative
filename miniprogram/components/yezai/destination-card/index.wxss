.destination-card {
  overflow: hidden;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.12);
}

.destination-card__cover {
  display: block;
  width: 100%;
  height: 420rpx;
}

.destination-card__body {
  padding-top: 24rpx;
}

.destination-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.destination-card__name {
  flex: 0 0 auto;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 42rpx;
  line-height: 1.45;
  font-weight: 500;
  color: #2b241d;
}

.destination-card__stats {
  flex: 1;
  padding-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.5;
  text-align: right;
  letter-spacing: 1rpx;
  color: #8a5a38;
}

.destination-card__desc {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.95;
  color: #6a5a4b;
}
