.journey-item {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.journey-item__cover {
  display: block;
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
}

.journey-item__body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.journey-item__head,
.journey-item__foot {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.journey-item__eyebrow,
.journey-item__meta,
.journey-item__extra,
.journey-item__tail {
  font-size: 22rpx;
  line-height: 1.8;
  color: #993921;
}

.journey-item__meta,
.journey-item__tail {
  color: #6a5a4b;
}

.journey-item__title {
  display: block;
  font-family: "STSong", "Songti SC", "Noto Serif CJK SC", serif;
  font-size: 38rpx;
  line-height: 1.55;
  font-weight: 500;
  color: #2b241d;
}

.journey-item__description {
  display: block;
  font-size: 27rpx;
  line-height: 1.95;
  color: #6a5a4b;
}
