.idea-card {
  overflow: hidden;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.12);
}

.idea-card__cover {
  display: block;
  width: 100%;
  height: 360rpx;
}

.idea-card__body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-top: 24rpx;
}

.idea-card__theme {
  align-self: flex-start;
  padding: 0;
  border-radius: 0;
  background: transparent;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: #993921;
}

.idea-card__title {
  font-family: "STSong", "Songti SC", "Noto Serif CJK SC", serif;
  font-size: 40rpx;
  line-height: 1.55;
  font-weight: 500;
  color: #2b241d;
}

.idea-card__summary {
  font-size: 27rpx;
  line-height: 2;
  color: #6a5a4b;
}

.idea-card__author {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6a5a4b;
}
