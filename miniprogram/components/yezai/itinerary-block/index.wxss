.itinerary-block__layout {
  display: flex;
  gap: 14rpx;
}

.itinerary-block__nav {
  flex: 0 0 96rpx;
  width: 96rpx;
  height: 1040rpx;
}

.itinerary-block__nav-inner {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.itinerary-day-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  padding: 0 12rpx;
  border-radius: 18rpx;
  background: rgba(0, 0, 0, 0.025);
  transition: background 0.2s ease, color 0.2s ease;
}

.itinerary-day-chip--active {
  background: rgba(209, 94, 20, 0.1);
}

.itinerary-day-chip__text {
  font-size: 26rpx;
  line-height: 1.2;
  font-weight: 500;
  color: #6a5a4b;
}

.itinerary-day-chip--active .itinerary-day-chip__text {
  color: #2b241d;
}

.itinerary-block__content {
  flex: 1;
  height: 1040rpx;
  padding-right: 0;
}

.itinerary-block__content-inner {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.itinerary-day-card {
  padding: 0 0 28rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.12);
  border-radius: 0;
  background: transparent;
}

.itinerary-day-card__head {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.itinerary-day-card__title-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.itinerary-day-card__day {
  flex: 0 0 auto;
  padding-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.3;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: #993921;
}

.itinerary-day-card__title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #2b241d;
}

.itinerary-day-card__modules {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 18rpx;
}

.itinerary-module {
  padding: 18rpx 0 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.itinerary-module__head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.itinerary-module__icon {
  position: relative;
  flex: 0 0 32rpx;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.itinerary-module__title {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #2b241d;
}

.itinerary-module__content {
  display: block;
  margin-top: 10rpx;
  padding-left: 46rpx;
  font-size: 25rpx;
  line-height: 1.85;
  color: #6a5a4b;
}

.itinerary-module__icon view {
  position: absolute;
  box-sizing: border-box;
}

.itinerary-icon__sheet {
  inset: 4rpx 5rpx 4rpx 7rpx;
  border: 2rpx solid #d15e14;
  border-radius: 6rpx;
}

.itinerary-icon__line {
  left: 12rpx;
  right: 9rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: #d15e14;
}

.itinerary-icon__line--a {
  top: 12rpx;
}

.itinerary-icon__line--b {
  top: 18rpx;
}

.itinerary-icon__car-top {
  top: 8rpx;
  left: 10rpx;
  width: 12rpx;
  height: 7rpx;
  border: 2rpx solid #d15e14;
  border-bottom: 0;
  border-radius: 5rpx 5rpx 0 0;
}

.itinerary-icon__car-body {
  top: 13rpx;
  left: 6rpx;
  width: 20rpx;
  height: 8rpx;
  border: 2rpx solid #d15e14;
  border-radius: 5rpx;
}

.itinerary-icon__wheel {
  top: 22rpx;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #d15e14;
}

.itinerary-icon__wheel--left {
  left: 9rpx;
}

.itinerary-icon__wheel--right {
  right: 9rpx;
}

.itinerary-icon__bowl {
  left: 7rpx;
  top: 12rpx;
  width: 18rpx;
  height: 9rpx;
  border: 2rpx solid #d15e14;
  border-top: 0;
  border-radius: 0 0 10rpx 10rpx;
}

.itinerary-icon__bowl-base {
  left: 12rpx;
  top: 23rpx;
  width: 8rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: #d15e14;
}

.itinerary-icon__roof {
  top: 7rpx;
  left: 7rpx;
  width: 18rpx;
  height: 18rpx;
  border-top: 2rpx solid #d15e14;
  border-left: 2rpx solid #d15e14;
  transform: rotate(45deg);
}

.itinerary-icon__house {
  top: 13rpx;
  left: 9rpx;
  width: 14rpx;
  height: 11rpx;
  border: 2rpx solid #d15e14;
  border-top: 0;
  border-radius: 0 0 3rpx 3rpx;
}

.itinerary-icon__bulb {
  top: 7rpx;
  left: 9rpx;
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid #d15e14;
  border-radius: 50%;
}

.itinerary-icon__bulb-base {
  top: 21rpx;
  left: 13rpx;
  width: 6rpx;
  height: 5rpx;
  border-radius: 0 0 2rpx 2rpx;
  background: #d15e14;
}

.itinerary-icon__pack {
  top: 10rpx;
  left: 9rpx;
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid #d15e14;
  border-radius: 4rpx;
}

.itinerary-icon__pack-top {
  top: 6rpx;
  left: 12rpx;
  width: 8rpx;
  height: 5rpx;
  border: 2rpx solid #d15e14;
  border-bottom: 0;
  border-radius: 4rpx 4rpx 0 0;
}

.itinerary-icon__mountain {
  top: 12rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 11rpx solid #d15e14;
}

.itinerary-icon__mountain--back {
  left: 5rpx;
  opacity: 0.5;
}

.itinerary-icon__mountain--front {
  left: 13rpx;
}

.itinerary-icon__supply-box {
  top: 8rpx;
  left: 7rpx;
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid #d15e14;
  border-radius: 4rpx;
}

.itinerary-icon__supply-cross-h {
  top: 16rpx;
  left: 11rpx;
  width: 10rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: #d15e14;
}

.itinerary-icon__supply-cross-v {
  top: 12rpx;
  left: 15rpx;
  width: 2rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #d15e14;
}

.itinerary-icon__dot {
  top: 12rpx;
  left: 12rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #d15e14;
}
