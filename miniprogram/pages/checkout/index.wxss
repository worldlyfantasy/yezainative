.checkout-page {
  padding-bottom: 180rpx;
}

.checkout-service__name {
  display: block;
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #241b14;
}

.checkout-service__meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b594d;
}

.checkout-field {
  margin-top: 16rpx;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.stepper__button {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #efe4d5;
  font-size: 36rpx;
  color: #241b14;
}

.stepper__value {
  min-width: 60rpx;
  text-align: center;
  font-size: 30rpx;
  color: #241b14;
}

.checkout-note {
  width: 100%;
  min-height: 180rpx;
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #d6c1aa;
  border-radius: 18rpx;
  background: #fffaf4;
  color: #241b14;
  font-size: 26rpx;
}
