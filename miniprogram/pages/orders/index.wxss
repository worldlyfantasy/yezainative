.order-tabs {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.order-tab {
  flex-shrink: 0;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d6c1aa;
  background: #fffaf4;
  font-size: 24rpx;
  color: #6b594d;
}

.order-tab--active {
  border-color: #8f3d24;
  color: #8f3d24;
}
