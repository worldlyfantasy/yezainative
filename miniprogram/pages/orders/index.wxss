/* 订单列表 Tab 栏：暖米底与页面一致，细分割线区分，点击有 hover 反馈 */
.order-tabs-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f5efe3;
  padding: 0 24rpx;
  border-bottom: 1rpx solid rgba(139, 89, 36, 0.12);
}

.order-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 8rpx 24rpx;
  position: relative;
  border-radius: 12rpx;
}

.order-tab--hover {
  background-color: rgba(139, 89, 36, 0.08);
}

.order-tab__text {
  font-size: 28rpx;
  color: #333;
}

.order-tab--active .order-tab__text {
  color: #e54b4b;
}

.order-tab__underline {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #e54b4b;
  border-radius: 3rpx;
}
