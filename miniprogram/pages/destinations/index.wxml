<view class="page-shell">
  <text class="eyebrow">土地与故事</text>
  <text class="page-title">目的地</text>
  <text class="page-subtitle">它们或许没有喧闹的景点，却有清晰的生活节奏。试着以关键词搜索，你会看见不同肌理。</text>

  <view class="section-block filter-shell">
    <input
      class="search-input destination-search-input"
      placeholder="搜索目的地或关键词"
      value="{{searchValue}}"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
      confirm-type="search"
    />
  </view>

  <view class="section-block">
    <view wx:if="{{destinations.length}}" class="card-stack">
      <destination-card wx:for="{{destinations}}" wx:key="id" destination="{{item}}" bind:cardtap="onDestinationTap"></destination-card>
    </view>
    <view wx:else class="empty-state">暂无匹配结果。</view>
  </view>
</view>

<app-tab-bar></app-tab-bar>
