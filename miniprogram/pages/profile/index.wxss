.profile-page {
  padding-bottom: 120rpx;
}

.profile-empty {
  position: relative;
  overflow: hidden;
  min-height: 520rpx;
  padding: 0;
}

.profile-empty__banner,
.profile-empty__mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.profile-empty__mask {
  background: linear-gradient(180deg, rgba(17, 11, 8, 0.22), rgba(17, 11, 8, 0.48));
}

.profile-empty__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-height: 520rpx;
  padding: 32rpx 28rpx;
}

.profile-empty__title,
.profile-empty__desc {
  color: #fff8f1;
}

.profile-empty__button {
  width: 100%;
  margin-top: 24rpx;
  background: #fff8f1;
  color: #8f3d24;
}

.profile-user__head {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-user__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.profile-user__meta {
  flex: 1;
}

.profile-user__member {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b594d;
}

.ghost-action {
  font-size: 24rpx;
  color: #8f3d24;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.shortcut-item {
  min-height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.shortcut-item__label {
  font-size: 28rpx;
  color: #241b14;
}

.profile-section-head {
  margin-bottom: 0;
}

.mini-order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.mini-order {
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 250, 244, 0.72);
}

.mini-order__name {
  display: block;
  font-size: 28rpx;
  color: #241b14;
}

.mini-order__meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6b594d;
}

.profile-empty-state {
  padding-bottom: 12rpx;
}
