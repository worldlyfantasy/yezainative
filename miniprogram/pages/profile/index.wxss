.profile-page {
  padding: 24rpx 36rpx 120rpx;
}

.profile-hero {
  position: relative;
  overflow: hidden;
  padding: 42rpx 36rpx;
  border: 1rpx solid rgba(151, 124, 91, 0.18);
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 85% 18%, rgba(255, 250, 242, 0.94), rgba(255, 250, 242, 0) 24%),
    radial-gradient(circle at 12% 82%, rgba(214, 190, 153, 0.2), rgba(214, 190, 153, 0) 28%),
    linear-gradient(150deg, rgba(255, 250, 242, 0.92), rgba(242, 230, 201, 0.76) 48%, rgba(226, 211, 181, 0.84));
  box-shadow: 0 24rpx 52rpx rgba(93, 71, 45, 0.08);
}

.profile-hero__glyph {
  position: absolute;
  z-index: 0;
  pointer-events: none;
  opacity: 0.14;
}

.profile-hero__glyph--ye {
  top: 22rpx;
  right: 40rpx;
  width: 164rpx;
  height: 164rpx;
  transform: rotate(8deg);
}

.profile-hero__glyph--zai {
  right: -6rpx;
  bottom: -10rpx;
  width: 188rpx;
  height: 188rpx;
  transform: rotate(-7deg);
}

.profile-hero__eyebrow,
.profile-hero__title,
.profile-hero__desc,
.profile-hero__button,
.profile-identity {
  position: relative;
  z-index: 1;
}

.profile-hero__eyebrow {
  display: block;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: rgba(143, 61, 36, 0.82);
}

.profile-hero__title {
  display: block;
  margin-top: 18rpx;
  padding-right: 140rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 54rpx;
  line-height: 1.32;
  font-weight: 500;
  color: #2a2119;
}

.profile-hero__desc {
  display: block;
  margin-top: 18rpx;
  max-width: 500rpx;
  font-size: 25rpx;
  line-height: 1.9;
  color: #5f5144;
}

.profile-hero__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 34rpx;
  min-height: 84rpx;
  padding: 0 38rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: #f8f1e7;
  background: linear-gradient(135deg, #9a6840, #7d5231);
  box-shadow: 0 14rpx 28rpx rgba(90, 64, 40, 0.16);
}

/* 未登录：单框 = 底图完整 + 中央乳白区文案与按钮 */
.profile-guest-wrap {
  margin-bottom: 0;
}

.profile-guest-card {
  position: relative;
  overflow: hidden;
  border-radius: 36rpx;
  border: 1rpx solid rgba(151, 124, 91, 0.12);
  box-shadow: 0 24rpx 52rpx rgba(93, 71, 45, 0.08);
}

.profile-guest-card__bg {
  display: block;
  width: 100%;
  height: auto;
}

/* 中间整体位置：改 top 可上下移动，如 58% 更靠下、45% 更靠上 */
.profile-guest-card__content {
  position: absolute;
  left: 50%;
  top: 58%;
  transform: translate(-50%, -50%);
  width: 86%;
  max-width: 560rpx;
  padding: 0;
  text-align: center;
}

.profile-guest-card__title {
  display: block;
  margin-top: 0;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 48rpx;
  line-height: 1.32;
  font-weight: 500;
  color: #2a2119;
  text-shadow: 0 2rpx 8rpx rgba(255, 250, 242, 0.8);
}

.profile-guest-card__desc {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.85;
  color: #3d352d;
  text-shadow: 0 2rpx 6rpx rgba(255, 250, 242, 0.7);
}

/* 用 view 实现，宽度由 padding 控制，无组件默认最小宽度 */
.profile-guest-card__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 100rpx;
  min-height: 64rpx;
  padding: 10rpx 40rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: #f8f1e7;
  background: linear-gradient(135deg, #9a6840, #7d5231);
  box-shadow: 0 14rpx 28rpx rgba(90, 64, 40, 0.16);
}

.profile-guest-card__button--pressing {
  opacity: 0.92;
}

.profile-identity {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 22rpx;
}

.profile-identity__row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.profile-identity__avatar {
  width: 132rpx;
  height: 132rpx;
  flex-shrink: 0;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 250, 242, 0.8);
  box-shadow: 0 12rpx 24rpx rgba(98, 79, 54, 0.12);
}

.profile-identity__meta {
  flex: 1;
  min-width: 0;
  padding-top: 2rpx;
}

.profile-identity__name {
  display: block;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 48rpx;
  line-height: 1.25;
  color: #2a2119;
}

.profile-identity__member {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(143, 61, 36, 0.8);
}

.profile-identity__note {
  display: block;
  margin-top: 4rpx;
  padding-left: 0;
  font-size: 24rpx;
  line-height: 1.75;
  color: #66584a;
}

/* 退出：无框，红褐色文字 + 右箭头，与「查看全部 →」同风格 */
.profile-identity__logout {
  flex-shrink: 0;
  align-self: center;
  margin-left: auto;
  margin-right: 40rpx;
  margin-bottom: 70rpx;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 0;
  line-height: 1.3;
  font-size: 24rpx;
}

.profile-identity__logout-text,
.profile-identity__logout-arrow {
  color: rgba(143, 61, 36, 0.88);
  font-weight: 500;
}

.profile-identity__logout-arrow {
  font-size: 26rpx;
  line-height: 1;
}

.profile-identity__logout--pressing {
  opacity: 0.75;
}

.profile-entry-grid {
  display: flex;
  flex-direction: row;
}

.profile-entry-grid .profile-entry-card:first-child {
  margin-right: 24rpx;
}

.profile-entry-card {
  flex: 1;
  min-width: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-height: 140rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(151, 124, 91, 0.16);
  border-radius: 30rpx;
  background:
    linear-gradient(180deg, rgba(255, 250, 242, 0.88), rgba(255, 248, 236, 0.7)),
    linear-gradient(135deg, rgba(214, 190, 153, 0.05), rgba(153, 57, 33, 0.03));
  box-shadow: 0 18rpx 32rpx rgba(93, 71, 45, 0.06);
  text-align: left;
}

.profile-entry-card--strong {
  background:
    linear-gradient(180deg, rgba(249, 237, 215, 0.96), rgba(241, 223, 190, 0.82)),
    linear-gradient(135deg, rgba(154, 104, 64, 0.06), rgba(153, 57, 33, 0.04));
  box-shadow: 0 20rpx 36rpx rgba(93, 71, 45, 0.09);
}

.profile-entry-card__glyph {
  position: absolute;
  right: 8rpx;
  bottom: 2rpx;
  width: 116rpx;
  height: 116rpx;
  opacity: 0.45;
  pointer-events: none;
}

.profile-entry-card__eyebrow {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: rgba(143, 61, 36, 0.7);
}

.profile-entry-card__head {
  position: relative;
  z-index: 1;
  width: 100%;
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 14rpx;
}

.profile-entry-card__title {
  display: block;
  flex: 1;
  min-width: 0;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 34rpx;
  line-height: 1.28;
  color: #2a2119;
}

.profile-entry-card__desc {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 10rpx;
  max-width: 220rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #66584a;
}

.profile-entry-card__arrow {
  display: block;
  font-size: 30rpx;
  line-height: 1;
  color: rgba(143, 61, 36, 0.72);
}

.profile-section-head {
  margin-bottom: 0;
}

.profile-section-head__body {
  flex: 1;
  min-width: 0;
}

.profile-section__note {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6a5a4b;
}

.profile-trip-group {
  display: flex;
  flex-direction: column;
}

.active-trip-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

/* 一行：左侧创作者 + 连接线 + 右侧行程卡片 */
.active-trip-row {
  display: flex;
  align-items: stretch;
  width: 100%;
  min-height: 0;
}

/* 左侧：创作者信息，点击进入创作者页 */
.active-trip-creator {
  flex: 0 0 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 18rpx;
  border: 1rpx solid rgba(151, 124, 91, 0.16);
  border-right: none;
  border-radius: 24rpx 0 0 24rpx;
  background: linear-gradient(180deg, rgba(255, 250, 242, 0.92), rgba(242, 230, 201, 0.75));
  box-shadow: 0 12rpx 28rpx rgba(93, 71, 45, 0.05);
  text-align: center;
}

.active-trip-creator__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 250, 242, 0.9);
  flex-shrink: 0;
}

.active-trip-creator__info {
  margin-top: 14rpx;
  min-width: 0;
}

.active-trip-creator__name {
  display: block;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1.3;
  color: #2a2119;
}

/* 中间连接线：体现路线由左侧创作者设计 */
.active-trip-connector {
  flex-shrink: 0;
  width: 3rpx;
  background: linear-gradient(180deg, rgba(151, 124, 91, 0.2), rgba(151, 124, 91, 0.35), rgba(151, 124, 91, 0.2));
}

/* 右侧：行程卡片，点击进入行程详情，无底部创作者信息 */
.active-trip-card-wrap {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  border: 1rpx solid rgba(151, 124, 91, 0.14);
  border-radius: 0 24rpx 24rpx 0;
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.95), rgba(250, 243, 231, 0.84));
  box-shadow: 0 18rpx 32rpx rgba(93, 71, 45, 0.06);
  text-align: left;
}

.active-trip-card-wrap .active-trip-card__cover {
  display: block;
  width: 100%;
  height: 200rpx;
}

.active-trip-card-wrap .active-trip-card__body {
  padding: 18rpx 20rpx 20rpx;
}

.active-trip-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.active-trip-card__title {
  display: block;
  flex: 1;
  min-width: 0;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 28rpx;
  line-height: 1.4;
  color: #2a2119;
}

.active-trip-card__badge {
  flex-shrink: 0;
  display: inline-block;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(143, 61, 36, 0.09);
  font-size: 20rpx;
  line-height: 1;
  color: #8f3d24;
}

.active-trip-card__desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #66584a;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.profile-empty-state {
  margin-top: 4rpx;
  padding: 40rpx 8rpx 8rpx;
}

.is-pressing {
  opacity: 0.96;
  transform: translateY(2rpx);
  box-shadow: 0 8rpx 20rpx rgba(90, 64, 40, 0.12);
}

.is-pressing-soft {
  opacity: 0.9;
}

.is-pressing-card {
  opacity: 0.94;
  transform: translateY(2rpx);
}
