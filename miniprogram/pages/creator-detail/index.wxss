.creator-opening {
  padding-bottom: 40rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.14);
}

.creator-top {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.creator-top__avatar {
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(189, 154, 95, 0.34);
}

.creator-top__name {
  margin-top: 8rpx;
  font-size: 62rpx;
}

.creator-top__stance {
  margin-top: 16rpx;
}

.creator-top__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 18rpx;
  margin-top: 18rpx;
}

.creator-top__descriptor {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #993921;
}

.creator-place-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.creator-place-item {
  padding: 0 0 16rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.08);
  text-align: left;
  font-size: 28rpx;
  color: #2b241d;
}

.creator-top__button {
  width: 100%;
}

.creator-bottom-action {
  padding-top: 8rpx;
}

.detail-card__title {
  display: block;
}

.compare-block {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-top: 26rpx;
}

.compare-block__title {
  font-family: "STSong", "Songti SC", "Noto Serif CJK SC", serif;
  font-size: 30rpx;
  font-weight: 500;
  color: #2b241d;
}

.creator-detail__list {
  margin-top: 28rpx;
}

.group-list,
.review-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  margin-top: 28rpx;
}

.group-item {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.1);
}

.group-item__name {
  display: block;
  font-family: "STSong", "Songti SC", "Noto Serif CJK SC", serif;
  font-size: 34rpx;
  font-weight: 500;
  color: #2b241d;
}

.group-item__meta,
.review-item__content,
.review-item__audience {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.95;
  color: #6a5a4b;
}

.review-item {
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.08);
}
