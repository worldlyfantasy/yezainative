<view class="home-page">
  <view class="hero">
    <swiper
      class="hero__swiper"
      indicator-dots="{{true}}"
      autoplay="{{true}}"
      circular="{{true}}"
      interval="1000000"
      duration="1000"
    >
      <swiper-item wx:for="{{heroSlides}}" wx:key="id">
        <view class="hero__slide hero__slide--{{item.variant}} {{item.tone === 'muted' ? 'hero__slide--muted' : ''}}" bindtap="onHeroTap" data-slug="{{item.targetIdeaSlug}}">
          <block wx:if="{{item.variant === 'photo'}}">
            <image class="hero__image" src="{{item.image}}" mode="aspectFill" binderror="onHeroImageError" data-src="{{item.image}}" data-id="{{item.id}}"></image>
            <view wx:if="{{item.showMask !== false}}" class="hero__mask"></view>
          </block>
          <block wx:else>
            <view class="hero__art">
              <view class="hero__art-band hero__art-band--top"></view>
              <view class="hero__art-band hero__art-band--middle"></view>
              <view class="hero__art-band hero__art-band--bottom"></view>
              <text class="hero__art-logo">野哉</text>
            </view>
            <view class="hero__mask hero__mask--art"></view>
          </block>
          <view wx:if="{{item.mark || item.title || item.desc || item.subDesc}}" class="hero__content">
            <text wx:if="{{item.mark}}" class="hero__mark">{{item.mark}}</text>
            <text class="hero__title">{{item.title}}</text>
            <text class="hero__desc">{{item.desc}}</text>
            <text wx:if="{{item.subDesc}}" class="hero__desc hero__desc--secondary">{{item.subDesc}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <view class="page-shell">
    <view class="home-note">
      <text class="home-note__text">看见那些沉淀着在地经验、有温度的路线\n为每一位奔赴山海的旅行者\n照亮一条通往真实旅途的路径</text>
    </view>

    <view class="section-block">
      <view class="section-head">
        <view>
          <text class="eyebrow">精选创作者</text>
        </view>
        <text class="section-link" bindtap="goCreators">查看全部 →</text>
      </view>
      <view class="card-stack">
        <creator-card wx:for="{{featuredCreators}}" wx:key="id" creator="{{item}}" bind:cardtap="onCreatorTap"></creator-card>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <view>
          <text class="eyebrow">精选目的地</text>
        </view>
        <text class="section-link" bindtap="goDestinations">浏览目的地 →</text>
      </view>
      <view class="card-stack">
        <destination-card wx:for="{{featuredDestinations}}" wx:key="id" destination="{{item}}" bind:cardtap="onDestinationTap"></destination-card>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <view>
          <text class="eyebrow">旅行文学</text>
        </view>
        <text class="section-link" bindtap="goIdeas">阅读更多 →</text>
      </view>
      <view class="card-stack">
        <idea-card wx:for="{{featuredIdeas}}" wx:key="id" idea="{{item}}" author-name="{{item.authorName}}" bind:cardtap="onIdeaTap"></idea-card>
      </view>
    </view>
  </view>
</view>

<app-tab-bar></app-tab-bar>
