.home-page {
  padding-bottom: 80rpx;
}

.hero {
  position: relative;
  height: 820rpx;
  overflow: hidden;
}

.hero__swiper,
.hero__slide {
  width: 100%;
  height: 100%;
}

.hero__slide {
  background: #e7dece;
}

.hero__image,
.hero__mask,
.hero__art {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero__mask {
  background: linear-gradient(180deg, rgba(21, 15, 11, 0.08), rgba(21, 15, 11, 0.3) 82%);
}

.hero__slide--muted .hero__image {
  opacity: 1;
}

.hero__slide--muted .hero__mask {
  background:
    linear-gradient(180deg, rgba(255, 251, 243, 0.03), rgba(247, 235, 211, 0.08) 46%, rgba(121, 78, 43, 0.05) 100%),
    linear-gradient(90deg, rgba(255, 248, 234, 0.03), rgba(255, 248, 234, 0));
}

.hero__mask--art {
  background:
    linear-gradient(180deg, rgba(255, 252, 244, 0.06), rgba(58, 34, 18, 0.18) 76%),
    linear-gradient(90deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
}

.hero__art {
  background:
    linear-gradient(180deg, #f2ead7 0%, #ece3d4 58%, #ede6da 100%);
}

.hero__art-band {
  position: absolute;
  left: -8%;
  width: 116%;
  border-radius: 999rpx;
  transform: rotate(-6deg);
}

.hero__art-band--top {
  top: -40rpx;
  height: 260rpx;
  background:
    linear-gradient(180deg, rgba(241, 208, 108, 0.94), rgba(233, 187, 80, 0.9));
}

.hero__art-band--middle {
  top: 300rpx;
  left: 40%;
  width: 92%;
  height: 300rpx;
  background:
    linear-gradient(180deg, rgba(198, 189, 176, 0.46), rgba(215, 206, 193, 0.64));
  transform: rotate(-10deg);
}

.hero__art-band--bottom {
  right: -12%;
  bottom: -120rpx;
  left: auto;
  width: 78%;
  height: 240rpx;
  background:
    linear-gradient(180deg, rgba(206, 124, 69, 0.9), rgba(170, 86, 40, 0.94));
  transform: rotate(-10deg);
}

.hero__art-logo {
  position: absolute;
  top: 116rpx;
  left: 58rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 120rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #9e3820;
  transform: rotate(-14deg);
}

.hero__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  height: 100%;
  padding: 72rpx 44rpx;
}

.hero__mark {
  display: block;
  font-size: 24rpx;
  letter-spacing: 6rpx;
  color: rgba(242, 230, 201, 0.92);
}

.hero__title {
  margin-top: 18rpx;
  max-width: 560rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 68rpx;
  line-height: 1.52;
  font-weight: 500;
  color: #F2E6C9;
}

.hero__desc {
  display: block;
  margin-top: 22rpx;
  max-width: 520rpx;
  font-size: 28rpx;
  line-height: 1.95;
  color: rgba(242, 230, 201, 0.86);
}

.hero__slide--art .hero__mark {
  color: rgba(123, 53, 24, 0.72);
}

.hero__slide--art .hero__title {
  color: #3b2a1f;
}

.hero__slide--art .hero__desc {
  color: rgba(70, 52, 41, 0.9);
}

.hero__desc--secondary {
  margin-top: 6rpx;
}

.home-note {
  padding-bottom: 36rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.14);
}

.home-note__text {
  display: block;
  font-size: 30rpx;
  line-height: 2;
  color: #5e5145;
}
