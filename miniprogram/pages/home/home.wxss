.home-page {
  padding-bottom: 80rpx;
}

.hero {
  position: relative;
  min-height: 820rpx;
  overflow: hidden;
}

.hero__image,
.hero__mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero__mask {
  background: linear-gradient(180deg, rgba(21, 15, 11, 0.08), rgba(21, 15, 11, 0.48) 82%);
}

.hero__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-height: 820rpx;
  padding: 72rpx 44rpx;
}

.hero__mark {
  display: block;
  font-size: 24rpx;
  letter-spacing: 6rpx;
  color: rgba(242, 230, 201, 0.92);
}

.hero__title {
  margin-top: 18rpx;
  max-width: 560rpx;
  font-family: "STSong", "Songti SC", "Noto Serif CJK SC", serif;
  font-size: 68rpx;
  line-height: 1.52;
  font-weight: 500;
  color: #F2E6C9;
}

.hero__desc {
  display: block;
  margin-top: 22rpx;
  max-width: 520rpx;
  font-size: 28rpx;
  line-height: 1.95;
  color: rgba(242, 230, 201, 0.86);
}

.home-join__actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 32rpx;
}

.home__wide-button {
  width: 100%;
}

.home-note {
  padding-bottom: 36rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.14);
}

.home-note__text {
  display: block;
  font-size: 30rpx;
  line-height: 2;
  color: #5e5145;
}

.home-simple-head {
  align-items: flex-start;
}

.home-inline-button {
  min-height: 68rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-item {
  padding-left: 24rpx;
  border-left: 3rpx solid rgba(153, 57, 33, 0.24);
}

.step-item__title {
  display: block;
  font-family: "STSong", "Songti SC", "Noto Serif CJK SC", serif;
  font-size: 32rpx;
  font-weight: 500;
  color: #2b241d;
}

.step-item__detail {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.95;
  color: #6a5a4b;
}

.home-join {
  padding: 0 0 12rpx;
  border: 0;
  border-top: 1rpx solid rgba(153, 57, 33, 0.14);
  border-radius: 0;
  background: transparent;
}

.home-join__desc {
  margin-top: 16rpx;
}
