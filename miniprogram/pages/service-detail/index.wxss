.service-gallery {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.service-gallery__hero-wrapper {
  position: relative;
}

.service-gallery__hero {
  display: block;
  width: 100%;
  height: 520rpx;
  border-radius: 18rpx;
}

.service-gallery__counter {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.55);
}

.service-gallery__counter-text {
  font-size: 24rpx;
  color: #ffffff;
}

.service-gallery__strip {
  width: 100%;
  white-space: nowrap;
}

.service-gallery__row {
  display: inline-flex;
  gap: 16rpx;
}

.service-gallery__thumb {
  flex: 0 0 auto;
  width: 220rpx;
  height: 168rpx;
  border-radius: 12rpx;
}

.service-hero {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.service-hero__title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 8rpx;
}

.service-hero__title {
  flex: 0 1 auto;
  min-width: 0;
  font-size: 62rpx;
}

/* 创作者卡片（与人物页 creator-card 一致）：头像+名字+标签「创作者」「带领者」+ 对该目的地的个人宣传语（引号），点击进入创作者页 */
/* 上下间距：margin-top 为与主标题的间距，margin-bottom 为与下方「标签/团期」的间距 */
.creator-quote.creator-card {
  margin-top: 60rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding-bottom: 28rpx;
}

.creator-quote--tappable:active {
  opacity: 0.88;
}

.creator-quote .creator-card__head {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.creator-quote .creator-card__avatar {
  width: 144rpx;
  height: 144rpx;
  flex-shrink: 0;
  border-radius: 50%;
  border: 1rpx solid rgba(189, 154, 95, 0.34);
}

.creator-quote .creator-card__meta {
  flex: 1;
  min-width: 0;
}

.creator-quote .creator-card__title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.creator-quote .creator-card__name {
  flex: 0 0 auto;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 40rpx;
  line-height: 1.45;
  font-weight: 500;
  color: #2b241d;
}

.creator-quote .creator-card__tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx 12rpx;
  flex: 1;
  padding-top: 6rpx;
}

.creator-quote .creator-card__tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(153, 57, 33, 0.2);
  background: rgba(189, 154, 95, 0.1);
  font-size: 20rpx;
  line-height: 1.2;
  letter-spacing: 1rpx;
  color: #8a5a38;
}

.creator-quote .creator-card__stance {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.9;
  color: #6a5a4b;
}

.service-hero__meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.service-info__body,
.service-creator__stance {
  font-size: 26rpx;
  line-height: 1.95;
  color: #6a5a4b;
}

.service-creator__button {
  width: 100%;
  margin-top: 24rpx;
}

/* 自定义标签网格（后台可配置） */
.service-tags {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 32rpx;
}

.service-tag {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 16rpx;
}

.service-tag--clickable {
  padding-right: 32rpx;
}

.service-tag__inner {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.service-tag__label {
  font-size: 24rpx;
  color: #6a5a4b;
}

.service-tag__value {
  font-size: 28rpx;
  font-weight: 500;
  color: #2b241d;
}

.service-tag__arrow {
  font-size: 26rpx;
  color: #999;
}

/* 选择团期（横向滑动条） */
.service-periods {
  margin-top: 40rpx;
}

.service-periods__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.service-periods__title {
  flex: 1;
}

.service-periods__more {
  font-size: 26rpx;
  color: #993921;
}

.service-periods__strip {
  width: 100%;
  white-space: nowrap;
}

.service-periods__row {
  display: inline-flex;
  gap: 20rpx;
  padding: 8rpx 0 8rpx 4rpx;
}

.period-card {
  position: relative;
  flex: 0 0 auto;
  width: 320rpx;
  min-width: 320rpx;
  padding: 28rpx 24rpx;
  background: rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 16rpx;
  transition: border-color 0.2s, background 0.2s;
  box-sizing: border-box;
  overflow: visible;
}

.period-card--selected {
  border-color: #993921;
  background: rgba(153, 57, 33, 0.08);
}

.period-card__check {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #993921;
}

.period-card__date {
  display: block;
  font-size: 26rpx;
  line-height: 1.4;
  color: #2b241d;
  margin-bottom: 8rpx;
  padding-right: 36rpx;
  white-space: normal;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.period-card--selected .period-card__date {
  color: #993921;
}

.period-card__price {
  font-size: 30rpx;
  font-weight: 600;
  color: #2b241d;
  margin-right: 16rpx;
}

.period-card__price--active {
  color: #993921;
}

.period-card__status {
  font-size: 26rpx;
  color: #6a5a4b;
}

/* 团期选择底部面板 */
.period-sheet {
  position: fixed;
  inset: 0;
  z-index: 1000;
}

.period-sheet__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
}

.period-sheet__panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 85vh;
  background: #f9f4ec;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 40rpx rgba(0, 0, 0, 0.18);
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 280ms cubic-bezier(0.32, 0.72, 0.2, 1);
}

.period-sheet__panel--active {
  transform: translateY(0);
}

.period-sheet__handle {
  width: 96rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.12);
  margin: 20rpx auto 12rpx;
}

.period-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 24rpx;
}

.period-sheet__title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2b241d;
}

.period-sheet__close {
  width: 56rpx;
  height: 56rpx;
  font-size: 40rpx;
  line-height: 56rpx;
  text-align: center;
  color: #6a5a4b;
}

.period-sheet__body {
  flex: 1;
  padding: 0 32rpx 24rpx;
  max-height: 60vh;
}

.period-sheet__section {
  margin-bottom: 32rpx;
}

.period-sheet__label {
  font-size: 28rpx;
  font-weight: 500;
  color: #2b241d;
  display: block;
  margin-bottom: 16rpx;
}

.period-sheet__versions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.period-version {
  position: relative;
  padding: 16rpx 28rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #2b241d;
  background: #fff;
}

.period-version--selected {
  border-color: #993921;
  background: rgba(153, 57, 33, 0.08);
  color: #993921;
}

.period-version__check {
  margin-left: 8rpx;
  font-weight: 600;
}

.period-sheet__months {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.period-month {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #6a5a4b;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 999rpx;
}

.period-month--active {
  background: rgba(153, 57, 33, 0.12);
  color: #993921;
  font-weight: 500;
}

.period-sheet__dates {
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.period-sheet__dates-inner {
  display: inline-flex;
  gap: 20rpx;
  padding: 8rpx 0;
}

.period-date {
  position: relative;
  flex: 0 0 auto;
  width: 300rpx;
  min-width: 300rpx;
  padding: 24rpx;
  padding-right: 44rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 16rpx;
}

.period-date--selected {
  border-color: #993921;
  background: rgba(153, 57, 33, 0.06);
}

.period-date__range {
  display: block;
  font-size: 24rpx;
  line-height: 1.4;
  color: #2b241d;
  margin-bottom: 8rpx;
  white-space: normal;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.period-date__price {
  font-size: 28rpx;
  font-weight: 600;
  color: #993921;
  margin-right: 8rpx;
}

.period-date__status {
  font-size: 24rpx;
  color: #6a5a4b;
}

.period-date__check {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #993921;
}

.period-sheet__hint {
  font-size: 24rpx;
  color: #6a5a4b;
}

.period-sheet__stepper {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.period-sheet__stepper .period-sheet__price {
  font-size: 32rpx;
  font-weight: 600;
  color: #993921;
}

.period-sheet__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.period-sheet__total {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.period-sheet__total-label {
  font-size: 28rpx;
  color: #2b241d;
}

.period-sheet__total-price {
  font-size: 40rpx;
  font-weight: 600;
  color: #993921;
}

.period-sheet__next {
  flex: 0 0 auto;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
  background: #2b241d;
  border-radius: 999rpx;
  border: none;
}

.period-sheet__next::after {
  border: none;
}

/* 步进器（面板内：小号、尺寸一致） */
.period-sheet__section .stepper {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
}

.period-sheet__section .stepper__button {
  width: 48rpx;
  height: 48rpx;
  min-width: 48rpx;
  min-height: 48rpx;
  padding: 0;
  font-size: 28rpx;
  line-height: 48rpx;
  text-align: center;
  color: #2b241d;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 10rpx;
  border: none;
  box-sizing: border-box;
}

.period-sheet__section .stepper__button::after {
  border: none;
}

.period-sheet__section .stepper__value {
  font-size: 28rpx;
  font-weight: 500;
  min-width: 40rpx;
  text-align: center;
}

.service-info__title {
  display: block;
}

.service-info__body--top {
  display: block;
  margin-top: 16rpx;
}

.service-creator__name {
  display: block;
  margin-top: 16rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 36rpx;
  font-weight: 500;
  color: #2b241d;
}

.media-sheet {
  position: fixed;
  inset: 0;
  z-index: 999;
}

.media-sheet__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.25);
}

.media-sheet__panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 140rpx;
  background: #f9f4ec;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -12rpx 40rpx rgba(0, 0, 0, 0.18);
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

.media-sheet__panel--active {
  transform: translateY(0);
}

.media-sheet__handle {
  width: 96rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.12);
  margin: 20rpx auto 12rpx;
}

.media-sheet__tabs {
  display: flex;
  padding: 0 32rpx 16rpx;
  gap: 16rpx;
}

.media-sheet__tab {
  padding: 10rpx 26rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  background: rgba(0, 0, 0, 0.04);
  color: #6a5a4b;
}

.media-sheet__tab--active {
  background: #ffffff;
  color: #2b241d;
  font-weight: 500;
}

.media-sheet__body {
  flex: 1;
  padding: 0 32rpx 40rpx;
}

.media-sheet__images {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.media-sheet__image {
  width: 100%;
  height: 420rpx;
  border-radius: 18rpx;
}
