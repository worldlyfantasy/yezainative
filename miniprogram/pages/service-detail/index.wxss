.service-gallery {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.service-gallery__hero {
  display: block;
  width: 100%;
  height: 520rpx;
  border-radius: 18rpx;
}

.service-gallery__strip {
  width: 100%;
  white-space: nowrap;
}

.service-gallery__row {
  display: inline-flex;
  gap: 16rpx;
}

.service-gallery__thumb {
  flex: 0 0 auto;
  width: 220rpx;
  height: 168rpx;
  border-radius: 12rpx;
}

.service-hero {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.service-hero__title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 8rpx;
}

.service-hero__title {
  flex: 0 1 auto;
  min-width: 0;
  font-size: 62rpx;
}

.service-hero__meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.service-hero__price {
  font-size: 30rpx;
  font-weight: 500;
  color: #2b241d;
}

.service-hero__duration,
.service-info__body,
.service-creator__stance {
  font-size: 26rpx;
  line-height: 1.95;
  color: #6a5a4b;
}

.service-hero__button,
.service-creator__button {
  width: 100%;
  margin-top: 24rpx;
}

.service-info__title {
  display: block;
}

.service-info__body--top {
  display: block;
  margin-top: 16rpx;
}

.service-creator__name {
  display: block;
  margin-top: 16rpx;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 36rpx;
  font-weight: 500;
  color: #2b241d;
}
