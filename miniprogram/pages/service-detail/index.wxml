<view wx:if="{{service}}" class="page-shell">
  <text class="back-link" bindtap="goBack">← 返回目的地</text>

  <view wx:if="{{heroCover}}" class="section-block service-gallery">
    <view class="service-gallery__hero-wrapper" bindtap="openMediaSheet">
      <image
        class="service-gallery__hero"
        src="{{heroCover}}"
        mode="aspectFill"
      ></image>
      <view wx:if="{{photoTotal}}" class="service-gallery__counter">
        <text class="service-gallery__counter-text">1/{{photoTotal}}</text>
      </view>
    </view>
    <scroll-view wx:if="{{photoGallery.length}}" class="service-gallery__strip" scroll-x="true" enable-flex="true">
      <view class="service-gallery__row">
        <image
          wx:for="{{photoGallery}}"
          wx:key="*this"
          class="service-gallery__thumb"
          src="{{item}}"
          mode="aspectFill"
          bindtap="openMediaSheet"
        ></image>
      </view>
    </scroll-view>
  </view>

  <view class="section-block paper-block">
    <view class="service-hero">
      <view class="service-hero__content">
        <text class="eyebrow">{{service.type}}</text>
        <view class="service-hero__title-row">
          <text class="page-title service-hero__title">{{service.name}}</text>
          <favorite-star
            favorited="{{service.isFavorited}}"
            notice-state="{{favoriteNoticeState}}"
            bind:toggle="toggleFavorite"
            bind:navigatefavorites="goFavorites"
          ></favorite-star>
        </view>
        <view wx:if="{{creator}}" class="creator-quote creator-card creator-quote--tappable" bindtap="goCreatorDetail">
          <view class="creator-card__head">
            <image class="creator-card__avatar" src="{{creator.avatar}}" mode="aspectFill"></image>
            <view class="creator-card__meta">
              <view class="creator-card__title-row">
                <text class="creator-card__name">{{creator.name}}</text>
                <view class="creator-card__tags">
                  <text class="creator-card__tag">创作者</text>
                  <text class="creator-card__tag">带领者</text>
                </view>
              </view>
              <text class="creator-card__stance">"{{service.creatorQuote || service.summary}}"</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{service.tags && service.tags.length > 0}}" class="service-tags">
      <view
        wx:for="{{service.tags}}"
        wx:key="key"
        class="service-tag {{item.clickable ? 'service-tag--clickable' : ''}}"
        data-key="{{item.key}}"
        bindtap="{{item.clickable ? 'onTagTap' : ''}}"
      >
        <view class="service-tag__inner">
          <text class="service-tag__label">{{item.label}}</text>
          <text class="service-tag__value">{{item.value}}</text>
        </view>
        <text wx:if="{{item.clickable}}" class="service-tag__arrow">></text>
      </view>
    </view>

    <view wx:if="{{groupPeriods && groupPeriods.length > 0}}" class="service-periods">
      <view class="service-periods__head">
        <text class="section-title service-periods__title">选择团期</text>
        <text class="service-periods__more" bindtap="onViewMorePeriods">查看更多 ></text>
      </view>
      <scroll-view class="service-periods__strip" scroll-x="true" enable-flex="true" show-scrollbar="{{false}}">
        <view class="service-periods__row">
          <view
            wx:for="{{groupPeriods}}"
            wx:key="id"
            class="period-card {{selectedPeriodId === item.id ? 'period-card--selected' : ''}}"
            data-period="{{item}}"
            bindtap="onSelectPeriod"
          >
            <view wx:if="{{selectedPeriodId === item.id}}" class="period-card__check">✓</view>
            <text class="period-card__date">{{item.dateLabel}}</text>
            <text class="period-card__price {{selectedPeriodId === item.id ? 'period-card__price--active' : ''}}">¥{{item.price}}</text>
            <text class="period-card__status">{{item.statusText}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{travelDetail}}" class="section-block travel-detail-shell">
    <view class="js-section-tabs-anchor travel-detail-tabs-anchor"></view>
    <view class="js-section-tabs travel-detail-tabs {{isSectionTabsSticky ? 'travel-detail-tabs--sticky' : ''}}">
      <section-tabs
        sections="{{travelDetail.sections}}"
        active-key="{{activeSectionKey}}"
        bind:tabtap="onSectionTabTap"
      ></section-tabs>
    </view>

    <block wx:for="{{travelDetail.sections}}" wx:key="key" wx:for-item="sectionItem">
      <view wx:if="{{sectionItem.key === 'highlights'}}" id="{{sectionItem.anchorId}}" class="travel-section">
        <view class="travel-section__head">
          <text class="section-title travel-section__title">{{sectionItem.title}}</text>
        </view>
        <view class="travel-highlights">
          <view
            wx:for="{{travelDetail.highlights}}"
            wx:key="id"
            wx:for-item="highlight"
            class="travel-highlight-card"
          >
            <text class="travel-highlight-card__title">{{highlight.title}}</text>
            <text class="travel-highlight-card__desc">{{highlight.description}}</text>
            <scroll-view
              wx:if="{{highlight.images && highlight.images.length}}"
              class="travel-highlight-card__gallery"
              scroll-x="true"
              enable-flex="true"
              show-scrollbar="{{false}}"
            >
              <view class="travel-highlight-card__gallery-row">
                <image
                  wx:for="{{highlight.images}}"
                  wx:key="*this"
                  wx:for-item="imageUrl"
                  class="travel-highlight-card__image"
                  src="{{imageUrl}}"
                  mode="aspectFill"
                  bindload="onTravelDetailMediaLoad"
                ></image>
              </view>
            </scroll-view>
          </view>
        </view>
      </view>

      <view wx:if="{{sectionItem.key === 'itinerary'}}" id="{{sectionItem.anchorId}}" class="travel-section">
        <view class="travel-section__head">
          <text class="section-title travel-section__title">{{sectionItem.title}}</text>
        </view>
        <itinerary-block itinerary="{{travelDetail.itinerary}}"></itinerary-block>
      </view>

      <view wx:if="{{sectionItem.key === 'costs'}}" id="{{sectionItem.anchorId}}" class="travel-section">
        <view class="travel-section__head">
          <text class="section-title travel-section__title">{{sectionItem.title}}</text>
        </view>
        <view class="travel-cost-stack">
          <cost-table
            wx:for="{{costTableGroups}}"
            wx:key="key"
            title="{{item.title}}"
            rows="{{item.rows}}"
          ></cost-table>
        </view>
      </view>

      <view wx:if="{{sectionItem.key === 'notices'}}" id="{{sectionItem.anchorId}}" class="travel-section">
        <view class="travel-section__head">
          <text class="section-title travel-section__title">{{sectionItem.title}}</text>
        </view>
        <view class="travel-cost-stack">
          <cost-table
            wx:for="{{travelDetail.notices}}"
            wx:key="key"
            title="{{item.title}}"
            content="{{item.content}}"
          ></cost-table>
        </view>
      </view>
    </block>
  </view>
  <block wx:else>
    <view class="section-block detail-grid">
      <view class="paper-block">
        <text class="section-title detail-card__title">适合谁</text>
        <view class="detail-list">
          <text wx:for="{{service.suitable}}" wx:key="*this" class="detail-list-item">· {{item}}</text>
        </view>
      </view>
      <view class="paper-block">
        <text class="section-title detail-card__title">不适合谁</text>
        <view class="detail-list">
          <text wx:for="{{service.notSuitable}}" wx:key="*this" class="detail-list-item">· {{item}}</text>
        </view>
      </view>
    </view>

    <view class="section-block detail-grid">
      <view class="paper-block">
        <text class="section-title detail-card__title">交付物</text>
        <view class="detail-list">
          <text wx:for="{{service.deliverables}}" wx:key="*this" class="detail-list-item">· {{item}}</text>
        </view>
      </view>
      <view class="paper-block">
        <text class="section-title detail-card__title">不包含</text>
        <view class="detail-list">
          <text wx:for="{{service.exclusions}}" wx:key="*this" class="detail-list-item">· {{item}}</text>
        </view>
      </view>
    </view>

    <view class="section-block detail-grid">
      <view class="paper-block">
        <text class="section-title service-info__title">交付周期</text>
        <text class="service-info__body">{{service.timeline}}</text>
      </view>
      <view class="paper-block">
        <text class="section-title service-info__title">修改规则</text>
        <text class="service-info__body">{{service.revision}}</text>
      </view>
      <view class="paper-block">
        <text class="section-title service-info__title">离线提醒</text>
        <text class="service-info__body">当前阶段仅保留服务说明，不接支付、合同与分账。</text>
      </view>
    </view>

    <view class="section-block paper-block">
      <text class="section-title detail-card__title">退款规则</text>
      <text class="service-info__body service-info__body--top">{{service.refund}}</text>
    </view>
  </block>

  <view wx:if="{{periodSheetVisible}}" class="period-sheet">
    <view class="period-sheet__backdrop" bindtap="closePeriodSheet"></view>
    <view class="period-sheet__panel {{periodSheetAnimating ? 'period-sheet__panel--active' : ''}}">
      <view class="period-sheet__handle"></view>
      <view class="period-sheet__header">
        <text class="period-sheet__title">版本/日期/人数</text>
        <view class="period-sheet__close" bindtap="closePeriodSheet">×</view>
      </view>
      <scroll-view class="period-sheet__body" scroll-y="true">
        <view class="period-sheet__section">
          <text class="period-sheet__label">版本</text>
          <view class="period-sheet__versions">
            <view
              wx:for="{{periodSheetVersions}}"
              wx:key="*this"
              class="period-version {{periodSheetSelectedVersion === item ? 'period-version--selected' : ''}}"
              data-version="{{item}}"
              bindtap="onSelectVersion"
            >
              {{item}}
              <text wx:if="{{periodSheetSelectedVersion === item}}" class="period-version__check">✓</text>
            </view>
          </view>
        </view>
        <view class="period-sheet__section">
          <text class="period-sheet__label">出发日期</text>
          <view class="period-sheet__months">
            <view
              wx:for="{{periodSheetMonths}}"
              wx:key="*this"
              class="period-month {{periodSheetActiveMonth === item ? 'period-month--active' : ''}}"
              data-month="{{item}}"
              bindtap="onSelectMonth"
            >{{item}}</view>
          </view>
          <scroll-view class="period-sheet__dates" scroll-x="true">
            <view class="period-sheet__dates-inner">
              <view
                wx:for="{{periodSheetDates}}"
                wx:key="id"
                class="period-date {{periodSheetSelectedDateId === item.id ? 'period-date--selected' : ''}}"
                data-date="{{item}}"
                bindtap="onSelectSheetDate"
              >
                <text class="period-date__range">{{item.dateLabel}}</text>
                <text class="period-date__price">¥{{item.price}}</text>
                <text class="period-date__status">{{item.statusText}}</text>
                <view wx:if="{{periodSheetSelectedDateId === item.id}}" class="period-date__check">✓</view>
              </view>
            </view>
          </scroll-view>
          <text class="period-sheet__hint">{{periodSheetGroupHint}}</text>
        </view>
        <view class="period-sheet__section">
          <text class="period-sheet__label">出行人数</text>
          <view class="period-sheet__stepper">
            <text class="period-sheet__price">¥ {{periodSheetTotalPrice}}</text>
            <view class="stepper">
              <button class="stepper__button" bindtap="decreaseSheetPeople">-</button>
              <text class="stepper__value">{{periodSheetPeople}}</text>
              <button class="stepper__button" bindtap="increaseSheetPeople">+</button>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="period-sheet__footer">
        <view class="period-sheet__total">
          <text class="period-sheet__total-label">总价</text>
          <text class="period-sheet__total-price">¥{{periodSheetTotalPrice}}</text>
        </view>
        <button class="period-sheet__next" bindtap="goToCheckout">下一步</button>
      </view>
    </view>
  </view>

  <view wx:if="{{mediaSheetVisible}}" class="media-sheet">
    <view class="media-sheet__backdrop" bindtap="closeMediaSheet"></view>
    <view class="media-sheet__panel {{mediaSheetAnimating ? 'media-sheet__panel--active' : ''}}">
      <view class="media-sheet__handle"></view>
      <view class="media-sheet__tabs">
        <view
          wx:for="{{mediaTabs}}"
          wx:key="key"
          class="media-sheet__tab {{index === activeMediaTabIndex ? 'media-sheet__tab--active' : ''}}"
          data-index="{{index}}"
          bindtap="onMediaTabChange"
        >
          {{item.label}}
        </view>
      </view>
      <scroll-view class="media-sheet__body" scroll-y="true">
        <view class="media-sheet__images">
          <image
            wx:for="{{mediaTabs[activeMediaTabIndex].images}}"
            wx:key="*this"
            class="media-sheet__image"
            src="{{item}}"
            mode="aspectFill"
          ></image>
        </view>
      </scroll-view>
    </view>
  </view>
</view>

<app-tab-bar></app-tab-bar>
