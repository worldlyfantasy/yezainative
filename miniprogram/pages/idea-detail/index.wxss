.article-page {
  padding-left: 56rpx;
  padding-right: 56rpx;
}

.article-card {
  padding-bottom: 40rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.14);
}

.article-card__title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 8rpx;
}

.article-card__title {
  flex: 0 1 auto;
  min-width: 0;
  font-size: 62rpx;
}

.article-blocks {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  margin-top: 36rpx;
}

.article-block {
  display: block;
}

.article-block--heading {
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 36rpx;
  line-height: 1.8;
  font-weight: 500;
  color: #2b241d;
}

.article-block--quote {
  padding-left: 24rpx;
  border-left: 3rpx solid rgba(153, 57, 33, 0.22);
  font-size: 28rpx;
  line-height: 2.05;
  color: #6a5a4b;
}

.article-block--paragraph {
  font-size: 30rpx;
  line-height: 2.15;
  color: #5f5246;
  text-indent: 2em;
  margin-bottom: 2.15em;
}

.article-author {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 0;
}

.article-author__avatar {
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  border-radius: 50%;
  border: 1rpx solid rgba(189, 154, 95, 0.34);
}

.article-author__body {
  flex: 1;
  min-width: 0;
}

.article-author__name {
  display: block;
  margin-top: 4rpx;
}

.article-author__stance {
  display: block;
  margin-top: 8rpx;
}

.article-author__arrow {
  flex-shrink: 0;
  font-size: 28rpx;
  color: rgba(153, 57, 33, 0.5);
}
