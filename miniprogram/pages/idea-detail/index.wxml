<view wx:if="{{idea}}" class="page-shell article-page">
  <text class="back-link" bindtap="goBack">← 返回文章列表</text>

  <view class="section-block article-card">
    <text class="eyebrow">主题：{{idea.theme}}</text>
    <text class="page-title article-card__title">{{idea.title}}</text>
    <text class="page-subtitle">{{idea.summary}}</text>
    <view class="action-row">
      <button class="ghost-button" bindtap="toggleFavorite">{{idea.isFavorited ? '已收藏' : '收藏故事'}}</button>
    </view>

    <view class="article-blocks">
      <block wx:for="{{blocks}}" wx:key="id">
        <text wx:if="{{item.type === 'heading'}}" class="article-block article-block--heading">{{item.content}}</text>
        <text wx:elif="{{item.type === 'quote'}}" class="article-block article-block--quote">{{item.content}}</text>
        <text wx:else class="article-block article-block--paragraph">{{item.content}}</text>
      </block>
    </view>

    <view class="article-cta">
      <text class="eyebrow">文末引导</text>
      <text class="article-cta__text">{{idea.cta}}</text>
    </view>
  </view>

  <view wx:if="{{author}}" class="section-block article-author">
    <text class="eyebrow">作者</text>
    <text class="section-title">{{author.name}}</text>
    <text class="page-subtitle">{{author.stance}}</text>
    <view class="article-author__actions">
      <button class="outline-button article-author__button" bindtap="goCreatorDetail">查看创作者</button>
      <button class="primary-button article-author__button" bindtap="handleOfflineOrder">离线模式，暂不开放联系</button>
    </view>
  </view>
</view>

<app-tab-bar></app-tab-bar>
