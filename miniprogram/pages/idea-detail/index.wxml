<view wx:if="{{idea}}" class="page-shell article-page">
  <text class="back-link" bindtap="goBack">← 返回文章列表</text>

  <view class="section-block article-card">
    <view class="article-card__title-row">
      <text class="page-title article-card__title">{{idea.title}}</text>
      <favorite-star
        favorited="{{idea.isFavorited}}"
        notice-state="{{favoriteNoticeState}}"
        bind:toggle="toggleFavorite"
        bind:navigatefavorites="goFavorites"
      ></favorite-star>
    </view>

    <view class="article-blocks">
      <block wx:for="{{blocks}}" wx:key="id">
        <text wx:if="{{item.type === 'heading'}}" class="article-block article-block--heading">{{item.content}}</text>
        <text wx:elif="{{item.type === 'quote'}}" class="article-block article-block--quote">{{item.content}}</text>
        <text wx:else class="article-block article-block--paragraph">{{item.content}}</text>
      </block>
    </view>
  </view>

  <view wx:if="{{author}}" class="section-block article-author" bindtap="goCreatorDetail">
    <image class="article-author__avatar" src="{{author.avatar}}" mode="aspectFill"></image>
    <view class="article-author__body">
      <text class="section-title article-author__name">{{author.name}}</text>
      <text class="page-subtitle article-author__stance">{{author.stance}}</text>
    </view>
    <text class="article-author__arrow">→</text>
  </view>
</view>

<app-tab-bar></app-tab-bar>
