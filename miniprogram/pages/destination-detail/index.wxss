.destination-hero {
  overflow: hidden;
  padding: 0 0 40rpx;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.14);
}

.destination-hero__cover {
  display: block;
  width: 100%;
  height: 520rpx;
}

.destination-hero__body {
  padding-top: 30rpx;
}

.destination-hero__title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 8rpx;
}

.destination-hero__title {
  flex: 0 1 auto;
  min-width: 0;
  font-size: 62rpx;
}

.card-stack {
  margin-top: 0;
}

.destination-stories__title {
  display: block;
  margin-bottom: 24rpx;
}

.destination-story-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.destination-story-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(153, 57, 33, 0.1);
}

.destination-story-item:last-child {
  border-bottom: none;
}

.destination-story-item__main {
  flex: 1;
  min-width: 0;
}

.destination-story-item__title {
  display: block;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 36rpx;
  font-weight: 500;
  line-height: 1.4;
  color: #2b241d;
}

.destination-story-item__summary {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #6a5a4b;
}

.destination-story-item__author {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #6a5a4b;
}

.destination-story-item__arrow {
  flex-shrink: 0;
  font-size: 28rpx;
  color: rgba(153, 57, 33, 0.5);
}

.destination-journeys__title {
  margin-bottom: 24rpx;
}
